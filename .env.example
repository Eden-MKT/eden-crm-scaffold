# === .env (VERSIONADO) — só variáveis de CLIENT com prefixo VITE_ ===
# Este .env é commitado de propósito para que o deploy do Lovable receba as VITE_*.
# NÃO coloque segredos de servidor aqui — use .env.local (veja abaixo).
VITE_SUPABASE_URL=https://SEU_PROJETO.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# E-mails da equipe (identificação Filipe vs João no dashboard)
VITE_TEAM_FILIPE_EMAIL=filipesenna59@gmail.com
# João: aceita vários e-mails separados por vírgula (gmail + hotmail)
VITE_TEAM_JOAO_EMAILS=joaopaulorodrigues97@gmail.com,joaopaulorodrigues97@hotmail.com

# === .env.local (GITIGNORED via *.local) — segredos de SERVIDOR/ferramentas ===
# Crie um arquivo .env.local com as chaves abaixo. Elas NÃO vão pro bundle nem
# pro git. As da IA WhatsApp também ficam nos Supabase Secrets (Edge Functions).
#
# SUPABASE_ACCESS_TOKEN=sbp_xxx        # Management API (schema/deploy/secrets)
# EVOLUTION_API_URL=https://sua-evolution.easypanel.host
# EVOLUTION_API_KEY=xxx
# EVOLUTION_WEBHOOK_TOKEN=xxx
# OPENAI_API_KEY=sk-proj-xxx
